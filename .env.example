# Core runtime
ENVIRONMENT="local"
NEXT_PUBLIC_API_BASE_URL="/api"
BACKEND_INTERNAL_BASE_URL="http://fastapi:8091"

# CORS
# 本地开发默认允许全部来源；非 local 环境建议显式配置。
# 可用逗号分隔或 JSON 数组，例如：
# CORS_ALLOW_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# CORS_ALLOW_ORIGINS='["https://script-hub.example.com"]'
CORS_ALLOW_ORIGINS=""
# 如需按模式放行，也可以配置正则，例如：
# CORS_ALLOW_ORIGIN_REGEX="https://.*\\.example\\.com"
CORS_ALLOW_ORIGIN_REGEX=""

# Local MySQL
# 本地直接运行时会使用 localhost/127.0.0.1
# Docker 容器内运行时，如果 DB_LOCAL_HOST 仍是 localhost/127.0.0.1，
# 后端会自动改连 DB_LOCAL_HOST_DOCKER，不需要手工切换。
DB_LOCAL_HOST="localhost"
DB_LOCAL_HOST_DOCKER="host.docker.internal"
DB_LOCAL_PORT="3306"

# Script Hub auth
SCRIPT_HUB_SESSION_SECRET="replace-with-long-random-secret"
# Optional one-time bootstrap for a fresh database:
# 1. Prefer pointing to a JSON file instead of embedding plaintext access keys in .env
SCRIPT_HUB_BOOTSTRAP_USERS_FILE=""
# 2. If no user seed file is provided and the database has no Script Hub users yet,
#    bootstrap will create an initial admin user. You can pin its key here; otherwise one is generated and printed once.
SCRIPT_HUB_BOOTSTRAP_ADMIN_KEY=""

# Team resources encryption
TEAM_RESOURCES_PASSWORD_ENCRYPTION_KEY="replace-with-password-encryption-key"
TEAM_RESOURCES_EXPORT_ENCRYPTION_KEY="replace-with-export-encryption-key"

# Agent
AGENT_API_KEY="replace-with-agent-api-key"
AGENT_PORT="9200"
